# Copie para .env na raiz do projeto (docker compose lê automaticamente se configurado)
# Nunca commite .env com chaves reais

# --- IA (exemplo OpenAI-compatible) ---
AI_ENABLED=false
OPENAI_API_KEY=
AI_ENDPOINT=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Ollama local (descomente e ajuste):
# AI_ENABLED=true
# AI_ENDPOINT=http://host.docker.internal:11434/v1
# OPENAI_API_KEY=ollama
# AI_MODEL=llama3.2
